{
  "manifest_version": 3,
  "name": "TrustFill: Auto-Compliance",
  "version": "1.0",
  "description": "Security Questionnaires on Autopilot.",
  "icons": {
    "128": "icon1.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}